# PostgreSQL
PG_URL=postgresql+asyncpg://username:password@localhost:5432/pet_hospital

# MongoDB
MONGO_URL=mongodb://localhost:27017/pet_hospital

# Redis
REDIS_URL=redis://:your_redis_password@localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pet-hospital

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# App
APP_ENV=development
APP_PORT=8000
